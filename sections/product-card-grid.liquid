{% comment %}
  Demo grid section that showcases the custom product-card snippet.
{% endcomment %}

<div class="tw-mx-auto tw-max-w-7xl tw-px-4 tw-py-12 sm:tw-px-6 lg:tw-px-8">
  {%- if section.settings.heading != blank -%}
    <h2 class="tw-mb-8 tw-text-2xl tw-font-bold tw-text-gray-900">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="tw-grid tw-grid-cols-2 tw-gap-4 sm:tw-gap-6 md:tw-grid-cols-3 lg:tw-grid-cols-4">
    {%- for block in section.blocks -%}
      {%- assign block_product = all_products[block.settings.product] -%}
      {%- if block_product != blank -%}
        {%- render 'product-card', product: block_product -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Product card grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product card component demo"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Product card grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
