{%- liquid
  assign price = product.price
  assign compare_price = product.compare_at_price
  assign on_sale = false
  if compare_price > price
    assign on_sale = true
  endif

  assign color_option_index = -1
  for option in product.options_with_values
    assign downcased_name = option.name | downcase
    if downcased_name == 'color' or downcased_name == 'colour'
      assign color_option_index = forloop.index0
    endif
  endfor

  # Structured swatch colors: a product.metafields.custom.color_swatch list
  # (metaobject_reference, each entry has a 'label' and a 'color' field) lets
  # a merchant pick real hex values per color name instead of us guessing
  # from the English word. Falls back to a hardcoded name->hex table below
  # for products that don't have this metafield configured.
  assign swatch_metaobjects = product.metafields.custom.color_swatch.value

  assign initial_variant = product.selected_or_first_available_variant
  assign primary_image = initial_variant.featured_image | default: product.featured_image

  assign initial_color_value = blank
  if color_option_index > -1
    assign initial_color_value = initial_variant.options[color_option_index]
  endif

  assign secondary_available = false
  if product.media.size > 1
    assign secondary_available = true
  endif

  # Hover image resolution order: a dedicated variant metafield (structured
  # data, the correct place for this) beats the legacy alt-text convention
  # ("{color}-secondary"), which beats just picking any other product photo.
  assign secondary_image = initial_variant.metafields.custom.secondary_image.value
  if secondary_image == nil and initial_color_value != blank
    assign secondary_alt_key = initial_color_value | append: '-secondary'
    for media_item in product.media
      if media_item.alt == secondary_alt_key
        assign secondary_image = media_item.preview_image
        break
      endif
    endfor
  endif
  if secondary_image == nil or secondary_image == primary_image
    for media_item in product.media
      assign candidate_image = media_item.preview_image
      if candidate_image != primary_image
        assign secondary_image = candidate_image
        break
      endif
    endfor
  endif
-%}

<product-card-swatches class="tw-group tw-block tw-h-full">
  <div class="tw-flex tw-h-full tw-flex-col tw-overflow-hidden tw-rounded-2xl tw-bg-white tw-p-4 tw-transition-shadow tw-duration-200 hover:tw-shadow-lg">
    <a href="{{ product.url }}" class="tw-relative tw-block tw-aspect-square tw-w-full tw-overflow-hidden tw-rounded-xl tw-bg-gray-50">
      {%- if on_sale -%}
        <span class="tw-absolute tw-left-3 tw-top-3 tw-z-[1] tw-rounded-full tw-border tw-border-solid tw-border-red-500 tw-bg-white tw-px-3 tw-py-1 tw-text-xs tw-font-semibold tw-text-red-600">
          {{ 'products.product.on_sale' | t | default: 'On Sale!' }}
        </span>
      {%- endif -%}

      {%- if primary_image -%}
        <img
          data-product-card-main-image
          src="{{ primary_image | image_url: width: 600 }}"
          srcset="{{ primary_image | image_url: width: 400 }} 400w, {{ primary_image | image_url: width: 600 }} 600w, {{ primary_image | image_url: width: 800 }} 800w"
          sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
          alt="{{ primary_image.alt | default: product.title | escape }}"
          width="{{ primary_image.width }}"
          height="{{ primary_image.height }}"
          loading="lazy"
          class="tw-absolute tw-inset-0 tw-h-full tw-w-full tw-rounded-2xl tw-border tw-border-solid tw-border-gray-200 tw-object-cover tw-object-center tw-transition-opacity tw-duration-300 tw-ease-out{% if secondary_available %} group-hover:tw-opacity-0{% endif %}"
        >
      {%- endif -%}

      {%- if secondary_available -%}
        <img
          data-product-card-secondary-image
          src="{{ secondary_image | image_url: width: 600 }}"
          srcset="{{ secondary_image | image_url: width: 400 }} 400w, {{ secondary_image | image_url: width: 600 }} 600w, {{ secondary_image | image_url: width: 800 }} 800w"
          sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
          alt=""
          aria-hidden="true"
          width="{{ secondary_image.width }}"
          height="{{ secondary_image.height }}"
          loading="lazy"
          class="tw-absolute tw-inset-0 tw-h-full tw-w-full tw-object-cover tw-object-center tw-opacity-0 tw-transition-opacity tw-duration-300 tw-ease-out group-hover:tw-opacity-100"
        >
      {%- endif -%}
    </a>

    {%- if color_option_index > -1 -%}
      <div class="tw-mt-4 tw-px-[2px] tw-flex tw-flex-wrap tw-gap-2 " role="group" aria-label="{{ product.options_with_values[color_option_index].name }}">
        {%- for value in product.options_with_values[color_option_index].values -%}
          {%- liquid
            assign swatch_variant = nil
            for variant in product.variants
              if variant.options[color_option_index] == value
                assign swatch_variant = variant
                break
              endif
            endfor
            assign swatch_image = swatch_variant.featured_image | default: primary_image
            assign swatch_key = value | handle | replace: '-', ''

            assign swatch_secondary_image = swatch_variant.metafields.custom.secondary_image.value
            if swatch_secondary_image == nil
              assign swatch_secondary_alt_key = value | append: '-secondary'
              for media_item in product.media
                if media_item.alt == swatch_secondary_alt_key
                  assign swatch_secondary_image = media_item.preview_image
                  break
                endif
              endfor
            endif
            if swatch_secondary_image == nil or swatch_secondary_image == swatch_image
              for media_item in product.media
                assign swatch_candidate_image = media_item.preview_image
                if swatch_candidate_image != swatch_image
                  assign swatch_secondary_image = swatch_candidate_image
                  break
                endif
              endfor
            endif

            assign swatch_hex = blank
            if swatch_metaobjects
              for swatch_ref in swatch_metaobjects
                if swatch_ref.label == value
                  assign swatch_hex = swatch_ref.color
                  break
                endif
              endfor
            endif
          -%}
          {%- if swatch_hex == blank -%}
            {%- capture swatch_hex -%}
              {%- case swatch_key -%}
                {%- when 'red' -%}#dc2626
                {%- when 'orange' -%}#f97316
                {%- when 'yellow' -%}#facc15
                {%- when 'green' -%}#16a34a
                {%- when 'blue' -%}#2563eb
                {%- when 'navy' -%}#1e3a8a
                {%- when 'purple' -%}#9333ea
                {%- when 'pink' -%}#f9a8d4
                {%- when 'black' -%}#111827
                {%- when 'white' -%}#ffffff
                {%- when 'gray' or 'grey' -%}#9ca3af
                {%- when 'brown' -%}#78350f
                {%- when 'teal' -%}#0d9488
                {%- when 'cyan' -%}#06b6d4
                {%- when 'beige' -%}#e7dfd0
                {%- when 'tan' -%}#d2b48c
                {%- when 'gold' -%}#d4af37
                {%- when 'silver' -%}#c0c0c0
                {%- when 'maroon' -%}#7f1d1d
                {%- when 'olive' -%}#556b2f
                {%- when 'mint' -%}#a7f3d0
                {%- when 'lavender' -%}#c4b5fd
                {%- when 'coral' -%}#fb7185
                {%- when 'turquoise' -%}#2dd4bf
                {%- when 'charcoal' -%}#374151
              {%- endcase -%}
            {%- endcapture -%}
            {%- assign swatch_hex = swatch_hex | strip -%}
          {%- endif -%}
          <button
            type="button"
            data-swatch
            data-image="{{ swatch_image | image_url: width: 600 }}"
            data-srcset="{{ swatch_image | image_url: width: 400 }} 400w, {{ swatch_image | image_url: width: 600 }} 600w, {{ swatch_image | image_url: width: 800 }} 800w"
            data-alt="{{ swatch_image.alt | default: product.title | escape }}"
            {%- if swatch_secondary_image %}
            data-secondary-image="{{ swatch_secondary_image | image_url: width: 600 }}"
            data-secondary-srcset="{{ swatch_secondary_image | image_url: width: 400 }} 400w, {{ swatch_secondary_image | image_url: width: 600 }} 600w, {{ swatch_secondary_image | image_url: width: 800 }} 800w"
            {%- endif %}
            aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-label="{{ value }}"
            title="{{ value }}"
            class="tw-h-5 tw-w-5 tw-flex-none tw-rounded-full tw-border-0 tw-ring-1 tw-ring-offset-1 tw-ring-transparent tw-transition hover:tw-ring-gray-300 aria-pressed:tw-ring-[#0A4874] aria-pressed:hover:tw-ring-gray-900 hover:tw-cursor-pointer"
            style="{% if swatch_hex != blank %}background-color: {{ swatch_hex }};{% if swatch_hex == '#ffffff' %} box-shadow: inset 0 0 0 1px rgb(0 0 0 / 0.1);{% endif %}{% else %}background-image: url('{{ swatch_image | image_url: width: 60 }}'); background-size: cover; background-position: center;{% endif %}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="tw-mt-4 tw-flex tw-flex-1 tw-flex-col tw-justify-end tw-gap-[6px]">
      {%- if product.vendor != blank -%}
        <p class="tw-text-sm tw-text-[#111111] tw-m-0">{{ product.vendor }}</p>
      {%- endif -%}

      <h3 class="tw-text-base tw-font-bold tw-leading-snug  tw-m-0">
        <a href="{{ product.url }}" class="hover:tw-underline tw-text-[#0A4874] tw-no-underline">{{ product.title | escape }}</a>
      </h3>

      <div class="tw-flex tw-items-center tw-gap-2">
        {%- if on_sale -%}
          <span class="tw-text-sm tw-text-[#111111] tw-line-through">{{ compare_price | money }}</span>
          <span class="tw-text-sm tw-font-semibold tw-text-[#FF0000]">{{ price | money }}</span>
        {%- else -%}
          <span class="tw-text-sm tw-font-semibold tw-text-gray-900">{{ price | money }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</product-card-swatches>
